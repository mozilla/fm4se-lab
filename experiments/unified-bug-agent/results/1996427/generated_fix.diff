+++ b/netwerk/dns/DNS.cpp
@@ -1500,6 +1500,34 @@
 bool
 DNSRequest::IsLocalOrPrivateAddress(const nsACString& aHost) {
+  // Resolve the host to IP(s) and check if any is local/private
+  nsCOMPtr<nsIDNSService> dns = do_GetService(NS_DNSSERVICE_CONTRACTID);
+  if (!dns) {
+    return false;
+  }
+
+  nsTArray<net::NetAddr> addrs;
+  nsresult rv = dns->GetNetAddrByName(aHost, addrs);
+  if (NS_FAILED(rv)) {
+    return false;
+  }
+
+  for (const auto& addr : addrs) {
+    if (addr.inet.family == AF_INET) {
+      uint32_t ip = ntohl(addr.inet.ip);
+      // 10.0.0.0/8
+      if ((ip & 0xff000000) == 0x0a000000) {
+        return true;
+      }
+      // 172.16.0.0/12
+      if ((ip & 0xfff00000) == 0xac100000) {
+        return true;
+      }
+      // 192.168.0.0/16
+      if ((ip & 0xffff0000) == 0xc0a80000) {
+        return true;
+      }
+      // 127.0.0.0/8 loopback
+      if ((ip & 0xff000000) == 0x7f000000) {
+        return true;
+      }
+    } else if (addr.inet.family == AF_INET6) {
+      // Check IPv6 localhost ::1
+      static const uint8_t localhost6[16] = {0};
+      if (memcmp(addr.inet.ipv6, localhost6, 15) == 0 &&
+          addr.inet.ipv6[15] == 1) {
+        return true;
+      }
+      // Check IPv6 unique local addresses fc00::/7
+      if ((addr.inet.ipv6[0] & 0xfe) == 0xfc) {
+        return true;
+      }
+    }
+  }
+  return false;
+}
