--- a/netwerk/protocol/http/TlsHandshaker.cpp
+++ b/netwerk/protocol/http/TlsHandshaker.cpp
@@ -200,6 +200,20 @@
 void
 TlsHandshaker::StartHandshake() {
+  // Check if DNS request indicates to bypass ECH for this host
+  bool bypassECH = false;
+  if (mDNSRequest) {
+    bypassECH = mDNSRequest->GetBypassECH();
+  }
+
+  if (bypassECH) {
+    // Disable ECH for this handshake to avoid internal_error alert
+    mTlsSocketControl->SetECHEnabled(false);
+  }
+
+  // Proceed with handshake as usual
+  mTlsSocketControl->StartHandshake();
 }
