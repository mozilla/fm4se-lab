+/* This patch restores the highlight markup wrapping matched search terms in search suggestion titles. */
+
 import {
-  // ... other imports
-} from "resource://gre/modules/SomeModule.jsm";
+  // existing imports
+} from "resource://gre/modules/SomeModule.jsm";
+
+/**
+ * Wrap matched substrings in the suggestion title with highlight markup.
+ * @param {string} title - The suggestion title.
+ * @param {Array<{start: number, end: number}>} matches - Array of match ranges.
+ * @returns {string} Highlighted title as HTML.
+ */
+function highlightMatches(title, matches) {
+  if (!matches || matches.length === 0) {
+    return title;
+  }
+
+  let highlighted = "";
+  let lastIndex = 0;
+
+  for (const { start, end } of matches) {
+    // Append text before the match
+    highlighted += escapeHTML(title.substring(lastIndex, start));
+    // Append matched text wrapped in highlight span
+    highlighted += `<span class="urlbarView-highlight">${escapeHTML(title.substring(start, end))}</span>`;
+    lastIndex = end;
+  }
+  // Append trailing text after last match
+  highlighted += escapeHTML(title.substring(lastIndex));
+  return highlighted;
+}
+
+/**
+ * Escape HTML special characters to avoid injection issues.
+ * @param {string} str
+ * @returns {string}
+ */
+function escapeHTML(str) {
+  return str.replace(/[&<>"']/g, c => {
+    switch (c) {
+      case "&": return "&amp;";
+      case "<": return "&lt;";
+      case ">": return "&gt;";
+      case "\"": return "&quot;";
+      case "'": return "&#39;";
+      default: return c;
+    }
+  });
+}
+
+export { highlightMatches };
+
+// Usage of highlightMatches should be restored in the code that generates the suggestion title markup.
