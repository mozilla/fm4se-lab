 bool
 BatteryManager::GetCharging(bool* aCharging)
 {
+  // On Windows, forward charging state from hal/HalBatteryInformation.cpp
+#ifdef XP_WIN
+  hal::BatteryInformation info;
+  hal::GetCurrentBatteryInformation(&info);
+  *aCharging = info.isCharging;
+  return true;
+#else
+  // Fallback or other platform implementation
+  *aCharging = false;
+  return false;
+#endif
 }
--- a/hal/HalBatteryInformation.cpp
+++ b/hal/HalBatteryInformation.cpp
@@ -30,6 +30,14 @@
+bool
+GetCurrentBatteryInformation(BatteryInformation* aInfo)
+{
+  // Windows specific implementation to get battery charging state
+  SYSTEM_POWER_STATUS status = {0};
+  if (!GetSystemPowerStatus(&status)) {
+    return false;
+  }
+  aInfo->isCharging = (status.ACLineStatus == 1);
+  return true;
+}
