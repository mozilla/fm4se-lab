--- a/gfx/VideoOverlay.cpp
+++ b/gfx/VideoOverlay.cpp
@@ -120,10 +120,44 @@
 bool
 VideoOverlay::ShouldEnableVideoSuperResolution()
 {
-  // Existing logic enabling Video Super Resolution based on GPU and driver version
-  return IsNvidiaGpu() && GetNvidiaDriverVersion() >= 530;
+  // Enable Video Super Resolution only on Windows when charging
+#if defined(XP_WIN)
+  bool isCharging = false;
+  // Query the battery charging state from BatteryManager
+  nsCOMPtr<nsIBatteryManager> batteryManager = do_GetService("@mozilla.org/battery-manager;1");
+  if (batteryManager) {
+    batteryManager->GetCharging(&isCharging);
+  }
+
+  if (!isCharging) {
+    return false;
+  }
+
+  // Check GPU type and driver version
+  if (IsNvidiaGpu()) {
+    uint32_t driverVersion = GetNvidiaDriverVersion();
+    if (driverVersion >= 530) {
+      return true;
+    }
+  } else if (IsIntelGpu()) {
+    uint32_t gen = GetIntelGen();
+    if (gen >= 10) {
+      return true;
+    }
+  }
+
+  return false;
+#else
+  // On non-Windows platforms, disable Video Super Resolution for now
+  return false;
+#endif
 }
--- a/dom/battery/BatteryManager.cpp
