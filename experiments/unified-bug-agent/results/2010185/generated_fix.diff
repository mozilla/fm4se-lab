+  // Updated Yelp suggestion row UI per Figma
+  _createYelpSuggestionRow(result) {
+    let row = new UrlbarResult(result);
+
+    // Append '[query] · Yelp' suffix to title
+    const query = result.query || "";
+    row.title = `${result.title} [${query}] \u00b7 Yelp`;
+
+    // Correctly position Sponsored label
+    if (result.isSponsored && row.sponsoredLabel) {
+      row.sponsoredLabel.style.display = "inline-block";
+      row.sponsoredLabel.style.position = "relative";
+      row.sponsoredLabel.style.top = "0";
+      row.sponsoredLabel.style.right = "0";
+    } else if (row.sponsoredLabel) {
+      row.sponsoredLabel.style.display = "none";
+    }
+
+    // Remove 'Feedback' label from menu buttons
+    if (row.menuButton) {
+      row.menuButton.textContent = "";
+      row.menuButton.setAttribute("aria-label", "Menu");
+    }
+
+    // Defer icon size changes until Nova update - do not set icon size here
+
+    // Show URLs on hover
+    if (row.element) {
+      row.element.addEventListener("mouseenter", () => {
+        if (result.url) {
+          row.showUrlTooltip(result.url);
+        }
+      });
+      row.element.addEventListener("mouseleave", () => {
+        row.hideUrlTooltip();
+      });
+    }
+
+    return row;
+  }