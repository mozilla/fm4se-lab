+  // To reduce race conditions and memory bloat, make a local copy of the event
+  mozilla::dom::EventInit init;
+  init.mBubbles = true;
+  init.mCancelable = false;
+
+  // Create a unique_ptr to ensure event memory is freed promptly
+  auto event = MakeUnique<WidgetEvent>(mozilla::dom::EventMessage::eNetworkStatusChange, init);
+
+  // Dispatch event synchronously and clear references immediately after dispatch
+  DispatchEvent(*event);
+  event.reset();
+
+  // Force a minor GC to reduce memory bloat after event dispatch
+  if (NS_IsMainThread()) {
+    nsCOMPtr<nsIGlobalObject> global = do_QueryInterface(GetOwnerGlobal());
+    if (global) {
+      nsJSContext::GarbageCollectNow(global->GetJSContext(), JS::GCReason::API);
+    }
+  }
