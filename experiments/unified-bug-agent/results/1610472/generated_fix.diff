+// Core providers manager logic without platform or UI dependencies.
+// This class handles managing providers and fetching results.
+
+import { SearchProviderCore } from "./providers/SearchProvider.sys.mjs";
+import { HistoryProviderCore } from "./providers/HistoryProvider.sys.mjs";
+
+export class UrlbarProvidersManagerCore {
+  constructor() {
+    this._providers = [
+      new SearchProviderCore(),
+      new HistoryProviderCore(),
+    ];
+  }
+
+  initialize() {
+    for (const provider of this._providers) {
+      provider.initialize();
+    }
+  }
+
+  async getResults(input) {
+    let results = [];
+    for (const provider of this._providers) {
+      let providerResults = await provider.getResults(input);
+      results.push(...providerResults);
+    }
+    return results;
+  }
+
+  destroy() {
+    for (const provider of this._providers) {
+      provider.destroy();
+    }
+  }
+}
+
+// Platform/UI specific providers extend or wrap these core providers,
+// passing platform context like window or UI hooks as needed.
