 interface nsIThreadRetargetableStreamListener : nsIStreamListener
 {
+  /**
+   * This interface extends nsIStreamListener to support retargeting stream events
+   * to a different thread. Implementations are required to guarantee strict
+   * ordering of OnDataAvailable, OnDataFinish, and OnStopRequest events.
+   *
+   * In particular, OnDataFinish will always be dispatched strictly before
+   * OnStopRequest. This ordering is enforced to avoid race conditions and ensure
+   * deterministic behavior of stream event handling.
+   *
+   * Consumers can rely on these guarantees when implementing listeners or
+   * retargeting logic.
+   */
+
+  // Existing methods...
 };
 
