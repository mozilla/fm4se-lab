+  // Modified to enforce explicit ordering:
+  // OnDataFinish events must be dispatched strictly before OnStopRequest.
+
+  if (mIsDispatching) {
+    return;
+  }
+
+  mIsDispatching = true;
+
+  while (true) {
+    Event* event = nullptr;
+
+    // Scan the queue to find OnDataFinish event if any pending before OnStopRequest
+    Event* onStopRequestEvent = nullptr;
+    for (auto it = mQueue.begin(); it != mQueue.end(); ++it) {
+      if ((*it)->IsOnStopRequest()) {
+        onStopRequestEvent = *it;
+        break;
+      }
+    }
+
+    if (onStopRequestEvent) {
+      // Check if there is OnDataFinish event before OnStopRequest event
+      Event* onDataFinishEvent = nullptr;
+      for (auto it = mQueue.begin(); it != mQueue.end(); ++it) {
+        if ((*it)->IsOnDataFinish()) {
+          onDataFinishEvent = *it;
+          break;
+        }
+        if (*it == onStopRequestEvent) {
+          break;
+        }
+      }
+
+      if (onDataFinishEvent) {
+        event = onDataFinishEvent;
+      } else {
+        event = onStopRequestEvent;
+      }
+    } else {
+      // No OnStopRequest event found, just dequeue next event normally
+      if (mQueue.empty()) {
+        mIsDispatching = false;
+        return;
+      }
+      event = mQueue.front();
+    }
+
+    mQueue.remove(event);
+    event->Dispatch();
+  }
