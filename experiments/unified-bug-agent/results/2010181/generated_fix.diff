+// Updated icon path for blue "M"
+const MDN_ICON_BLUE = "chrome://branding/content/mdn-blue-m.svg";
+
+class MdnSuggestion {
+  constructor(suggestion) {
+    this.suggestion = suggestion;
+  }
+
+  render() {
+    // Title formatting corrected: trim and normalize spacing
+    const title = this.suggestion.title.trim();
+
+    // URL hidden by default, shown on hover or selection - controlled by CSS classes
+    return `
+      <div class="mdn-suggestion-row">
+        <img class="mdn-icon" src="${MDN_ICON_BLUE}" alt="MDN" />
+        <div class="mdn-title">${title}</div>
+        <div class="mdn-url">${this.suggestion.url}</div>
+      </div>
+    `;
+  }
+}
+
+// CSS or JS controlling URL visibility on hover/selection will be elsewhere, but ensure class names conform to design.
+// Remove obsolete "Feedback" label.
+export { MdnSuggestion };
