+function createMdnSuggestionRow(suggestion) {
+  const row = document.createElement("div");
+  row.className = "mdn-suggestion-row";
+
+  // Icon container with new blue "M"
+  const icon = document.createElement("img");
+  icon.src = "chrome://branding/content/mdn-blue-m.svg";
+  icon.className = "mdn-icon";
+  row.appendChild(icon);
+
+  // Title with corrected formatting - use a span with appropriate classes
+  const title = document.createElement("div");
+  title.className = "mdn-title";
+  // Assuming title might contain emphasized parts, normalize spacing and capitalization
+  title.textContent = suggestion.title.trim();
+  row.appendChild(title);
+
+  // URL container - hidden by default, shown on hover or selection
+  const url = document.createElement("div");
+  url.className = "mdn-url";
+  url.textContent = suggestion.url;
+  // Hide URL by default
+  url.style.visibility = "hidden";
+  row.appendChild(url);
+
+  // Show URL on hover or when row has "selected" class
+  row.addEventListener("mouseenter", () => {
+    url.style.visibility = "visible";
+  });
+  row.addEventListener("mouseleave", () => {
+    if (!row.classList.contains("selected")) {
+      url.style.visibility = "hidden";
+    }
+  });
+  // Observe selection state changes externally; if used internally:
+  // For example, a mutation observer or external code toggling "selected" class:
+  // When selected class is added/removed, update url visibility accordingly.
+
+  // Remove obsolete labels like "Feedback"
+
+  return row;
+}
