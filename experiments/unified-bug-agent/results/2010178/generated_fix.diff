--- a/browser/components/urlbar/QuickSuggest.sys.mjs
+++ b/browser/components/urlbar/QuickSuggest.sys.mjs
@@ -450,15 +450,37 @@
-function renderAMPRow(suggestion, isTopPick) {
-  return html`
-    <div class="amp-suggestion-row">
-      <span class="amp-title">${suggestion.title}</span>
-      <span class="separator"> - </span>
-      <span class="amp-source">${suggestion.source}</span>
-    </div>
-  `;
-}
+function renderAMPRow(suggestion, isTopPick) {
+  // Handler to show URL on hover or selection
+  function showURL(e) {
+    const urlLabel = e.currentTarget.querySelector(".amp-url");
+    if (urlLabel) {
+      urlLabel.style.display = "inline";
+    }
+  }
+
+  function hideURL(e) {
+    const urlLabel = e.currentTarget.querySelector(".amp-url");
+    if (urlLabel) {
+      urlLabel.style.display = "none";
+    }
+  }
+
+  return html`
+    <div class="amp-suggestion-row"
+         @mouseenter=${showURL}
+         @mouseleave=${hideURL}
+         @focus=${showURL}
+         @blur=${hideURL}
+         tabindex="0"
+    >
+      <span class="amp-title">${suggestion.title}</span>
+      <span class="separator"> · </span>
+      <span class="amp-source">${suggestion.source}</span>
+      ${isTopPick ? html`<span class="sponsored-label">Sponsored</span>` : ""}
+      <span class="amp-url" style="display:none">${suggestion.url}</span>
+    </div>
+  `;
+}
