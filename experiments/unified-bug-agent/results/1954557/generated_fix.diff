+// Fix to prevent overwriting newer built-in addon versions with older ones during upgrade
+function maybeUpgradeSystemAddon(addon) {
+  const existing = getAddonPreferences(addon.id);
+  if (existing) {
+    // Only overwrite if new addon version is greater than existing version
+    if (isBuiltIn(addon) && isBuiltIn(existing)) {
+      if (compareVersions(addon.version, existing.version) <= 0) {
+        // New version is older or equal, do not overwrite
+        return;
+      }
+    }
+  }
+  setAddonPreferences(addon.id, addon);
+}
