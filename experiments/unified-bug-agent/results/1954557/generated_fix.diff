+// Modified function: always prefer highest version for built-in addons regardless of location
+export function selectBestExtension(extensions) {
+  return extensions.sort((a, b) => {
+    const aBuiltIn = a.isBuiltIn;
+    const bBuiltIn = b.isBuiltIn;
+
+    if (aBuiltIn && bBuiltIn) {
+      // Both built-in: highest version wins
+      return compareVersions(a.version, b.version);
+    }
+
+    if (aBuiltIn && !bBuiltIn) {
+      // Prefer built-in with higher version
+      return compareVersions(a.version, b.version);
+    }
+    if (!aBuiltIn && bBuiltIn) {
+      return compareVersions(a.version, b.version);
+    }
+
+    // Neither built-in: fallback to location priority then version
+    if (a.location !== b.location) {
+      return a.location - b.location;
+    }
+    return compareVersions(a.version, b.version);
+  })[0];
+}
 
