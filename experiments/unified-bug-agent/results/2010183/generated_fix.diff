+class WikipediaSuggestionRow extends HTMLElement {
+  constructor() {
+    super();
+    this.attachShadow({ mode: "open" });
+  }
+
+  connectedCallback() {
+    this.render();
+  }
+
+  render() {
+    this.shadowRoot.innerHTML = `
+      <style>
+        .icon {
+          width: 24px;
+          height: 24px;
+        }
+        .title {
+          font-weight: bold;
+        }
+        .recommended-label {
+          font-size: 12px;
+          color: var(--urlbar-secondary-text-color, #6a6a6a);
+          margin-top: 2px;
+        }
+        .row {
+          display: flex;
+          flex-direction: column;
+        }
+      </style>
+      <div class="row">
+        <img class="icon" src="${this.getAttribute("icon")}" />
+        <div class="title">${this.getAttribute("title")}</div>
+        <div class="recommended-label">Recommended</div>
+      </div>
+    `;
+  }
+}
+
+customElements.define("wikipedia-suggestion-row", WikipediaSuggestionRow);