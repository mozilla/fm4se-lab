+    // Render the suggestion row UI.
+    renderSuggestion(suggestion) {
+      // Add 'Recommended' label below suggestion text for Wikipedia suggestions.
+      const isWikipedia = suggestion.providerName === "wikipedia";
+
+      return html`
+        <div class="suggestion-row">
+          <img src=${suggestion.icon} class="suggestion-icon" />
+          <div class="suggestion-text">${suggestion.title}</div>
+          ${isWikipedia
+            ? html`<div class="suggestion-subtext recommended-label">Recommended</div>`
+            : null}
+        </div>
+      `;
+    }
+
+    static get styles() {
+      return css`
+        .suggestion-icon {
+          width: 24px;
+          height: 24px;
+        }
+        .recommended-label {
+          font-size: 12px;
+          color: var(--urlbar-secondary-text-color, #6a6a6a);
+          margin-top: 2px;
+        }
+      `;
+    }
