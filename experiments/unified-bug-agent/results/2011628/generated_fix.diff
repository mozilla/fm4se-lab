--- a/testing/web-platform/tests/wpt/mimesniff/html-comments.html
+++ b/testing/web-platform/tests/wpt/mimesniff/html-comments.html
@@ -0,0 +1,40 @@
+<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>HTML comment sniffing test</title>
+</head>
+<body>
+  <script>
+    async function fetchBlob(content) {
+      return new Blob([content], {type: "application/octet-stream"});
+    }
+
+    async function sniffHTML(content) {
+      let blob = await fetchBlob(content);
+      let response = await fetch(URL.createObjectURL(blob));
+      let text = await response.text();
+      return text;
+    }
+
+    function isHTML(content) {
+      // If the content is parsed/rendered as HTML, the body will have child nodes.
+      let parser = new DOMParser();
+      let doc = parser.parseFromString(content, "text/html");
+      return doc.body.childNodes.length > 0;
+    }
+
+    async function test() {
+      // Test strings starting with <!-- followed by various characters
+      let tests = [
+        "<!--",
+        "<!-- ",
+        "<!-->",
+        "<!--x",
+        "<!-->",
+        "<!--!",
+      ];
+      for (let t of tests) {
+        let parsedAsHTML = isHTML(t);
+        console.log(`Content: ${JSON.stringify(t)} parsed as HTML: ${parsedAsHTML}`);
+      }
+    }
+    test();
+  </script>
+</body>
+</html>