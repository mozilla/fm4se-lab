-void* gc::get_output_buffer(size_t size) {
-    // Original implementation with unsafe concurrent buffer allocation
-    // leading to crashes and corruption.
-    void* buffer = allocate_buffer(size);
-    return buffer;
-}
+void* gc::get_output_buffer(size_t size) {
+    // Refactored to enforce thread-safe buffer allocation
+    static mozilla::StaticMutex bufferMutex;
+    static void* buffer = nullptr;
+    static size_t bufferSize = 0;
+
+    mozilla::StaticMutexAutoLock lock(bufferMutex);
+
+    if (buffer && bufferSize < size) {
+        js_free(buffer);
+        buffer = nullptr;
+        bufferSize = 0;
+    }
+
+    if (!buffer) {
+        buffer = js_malloc(size);
+        if (!buffer)
+            return nullptr;
+        bufferSize = size;
+    }
+
+    return buffer;
+}
