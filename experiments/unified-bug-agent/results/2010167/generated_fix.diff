+    // Refactor to ensure thread-safe OOM unsafe region entry
+    static mozilla::StaticMutex oomMutex;
+    mozilla::StaticMutexAutoLock lock(oomMutex);
+
+    oomUnsafe = true;
+}
+
+void js::AutoEnterOOMUnsafeRegion::reportIfFailed() {
+    static mozilla::StaticMutex oomMutex;
+    mozilla::StaticMutexAutoLock lock(oomMutex);
+    if (!errorReported) {
+        cx->handleOutOfMemory();
+        errorReported = true;
+    }
+}
