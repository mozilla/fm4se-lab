+import { execSync } from "child_process";
+import { existsSync, readFileSync } from "fs";
+import { join } from "path";
+
+// NodeHTTPServers class providing HTTP and HTTPS test servers
+class NodeHTTPServers {
+  constructor() {
+    this._servers = new Map();
+  }
+
+  startHTTP(port = 0) {
+    const http = require("http");
+    const server = http.createServer((req, res) => {
+      res.writeHead(200, { "Content-Type": "text/plain" });
+      res.end("hello world\n");
+    });
+    return new Promise((resolve, reject) => {
+      server.listen(port, () => {
+        this._servers.set(server, "http");
+        resolve(server);
+      });
+      server.on("error", reject);
+    });
+  }
+
+  async startHTTPS(port = 0) {
+    const https = require("https");
+    const certDir = join(__dirname, "certs");
+    const keyPath = join(certDir, "server.key");
+    const certPath = join(certDir, "server.crt");
+
+    if (!existsSync(keyPath) || !existsSync(certPath)) {
+      throw new Error("Certificate files not found in certs directory");
+    }
+
+    // Import cert into certificate DB for xpcshell environment
+    this._importCert(certPath);
+
+    const key = readFileSync(keyPath);
+    const cert = readFileSync(certPath);
+
+    const options = { key, cert };
+
+    const server = https.createServer(options, (req, res) => {
+      res.writeHead(200, { "Content-Type": "text/plain" });
+      res.end("hello secure world\n");
+    });
+
+    return new Promise((resolve, reject) => {
+      server.listen(port, () => {
+        this._servers.set(server, "https");
+        resolve(server);
+      });
+      server.on("error", reject);
+    });
+  }
+
+  _importCert(certPath) {
+    // Only import if in xpcshell environment with certutil available
+    try {
+      const certutil = "certutil";
+      // Check if certutil exists
+      execSync(`${certutil} -V -n ""`, { stdio: "ignore" });
+      // Import the cert
+      execSync(`${certutil} -A -n "test-server-cert" -t "TCu,Cu,Tu" -i "${certPath}" -d sql:$HOME/.pki/nssdb`);
+    } catch (e) {
+      // If certutil not found or error importing cert, log and continue
+      // We do not fail tests on cert import failure
+      console.warn("Certificate import failed or certutil not found, skipping import.");
+    }
+  }
+
+  stopAll() {
+    for (const [server, type] of this._servers) {
+      server.close();
+      this._servers.delete(server);
+    }
+  }
+}
+
+export { NodeHTTPServers };
