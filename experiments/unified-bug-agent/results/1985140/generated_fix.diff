+static void
+DisplayReconfigurationCallback(CGDirectDisplayID display,
+                               CGDisplayChangeSummaryFlags flags,
+                               void *userInfo)
+{
+  OSXVsyncSource* vsyncSource = static_cast<OSXVsyncSource*>(userInfo);
+
+  // Call existing reconfiguration handling logic (if any)
+  vsyncSource->OnDisplayReconfiguration(display, flags);
+}
+
+void
+OSXVsyncSource::OnDisplayReconfiguration(CGDirectDisplayID aDisplay,
+                                        CGDisplayChangeSummaryFlags aFlags)
+{
+  // Unregister and re-register the display reconfiguration callback to ensure proper handling
+  CGDisplayRemoveReconfigurationCallback(DisplayReconfigurationCallback, this);
+  CGDisplayRegisterReconfigurationCallback(DisplayReconfigurationCallback, this);
+
+  // Restart the VsyncRefreshDriverTimer to ensure it is running after display changes
+  if (mVsyncRefreshTimer) {
+    mVsyncRefreshTimer->Stop();
+    mVsyncRefreshTimer->Start();
+  }
+}
