+static void
+RegExpFinalize(JSFreeOp* fop, JSObject* obj)
+{
+    RegExpShared* shared = GetRegExpShared(obj);
+    if (shared) {
+        // Properly release the RegExpShared to avoid leaks and use-after-free
+        shared->release();
+    }
+
+    // Clear any private data or reserved slots if needed to avoid dangling pointers
+    obj->setPrivate(nullptr);
+}
