+  onIdentityBoxClick(event) {
+    // Ensure popup opens when clicking identity box on trusted about pages.
+    if (!this._trustPanelPopup) {
+      return;
+    }
+
+    // Call showPopup with correct anchorElement
+    const anchor = this._trustPanelPopup.anchorElement;
+    if (anchor && anchor.offsetParent !== null) {
+      this._trustPanelPopup.showPopup(anchor);
+    }
+  }
+