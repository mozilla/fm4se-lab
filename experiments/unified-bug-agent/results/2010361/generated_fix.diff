+import { Services } from "resource://gre/modules/Services.sys.mjs";
+
+export class TrustPanelPopup {
+  get anchorElement() {
+    // Determine if current page is a trusted about page.
+    // On such pages, identity box anchor may be hidden, so use an alternative visible element.
+    const trustedAboutPages = new Set([
+      "about:welcome",
+      "about:preferences",
+      "about:addons",
+      "about:config",
+      "about:debugging",
+      "about:privatebrowsing",
+      "about:profiles",
+      "about:performance",
+      "about:crashes",
+      "about:downloads",
+      "about:logins",
+      "about:protections",
+      "about:sessionrestore",
+    ]);
+
+    let currentURI = null;
+    try {
+      currentURI = Services.uriFixup.createExposableURI(window.location.href).spec;
+    } catch {
+      currentURI = window.location.href;
+    }
+
+    if (trustedAboutPages.has(currentURI)) {
+      // Return a visible element on trusted about pages.
+      // Identity box anchor is hidden, so fallback to urlbar or toolbar element.
+      let altAnchor = document.getElementById("urlbar") || document.getElementById("toolbar-menubar");
+      if (altAnchor && altAnchor.offsetParent !== null) {
+        return altAnchor;
+      }
+    }
+
+    // Default anchor element (identity box)
+    return document.getElementById("identity-box-anchor");
+  }
+}
