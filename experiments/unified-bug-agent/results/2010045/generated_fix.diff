+// New method to check if there is a user-added certificate exception
+bool
+CertVerifier::HasUserCertException(const nsIURI* aURI, nsIX509Cert* aCert) {
+  // Logic to check if the user has added a certificate exception for the given cert and URI.
+  // This typically involves querying the certificate override service.
+  nsCOMPtr<nsICertOverrideService> overrideSvc = do_GetService("@mozilla.org/security/certoverride;1");
+  if (!overrideSvc) {
+    return false;
+  }
+
+  bool hasException = false;
+  nsresult rv = overrideSvc->HasMatchingOverride(aURI, aCert, &hasException);
+  if (NS_FAILED(rv)) {
+    return false;
+  }
+  return hasException;
+}
