@@ -450,7 +450,15 @@
 bool
 GPUProcessHost::Start()
 {
-  // Regular startup code here...
+  // On Android, bindService() can throw DeadObjectException repeatedly,
+  // causing GPU process restart failures.
+  // We add a try-catch block to handle this gracefully and avoid crashes.
+
+  try {
+    // Regular startup code here...
+    return true;
+  } catch (const JavaException& e) {
+    if (e.IsDeadObjectException()) {
+      gfxCriticalNote << "[GPUProcessHost] DeadObjectException during bindService(), deferring GPU process start.";
+      return false;
+    }
+    throw;
+  }
 }
