+pub struct Connection {
+    output_buffer: Arc<Mutex<Option<Vec<u8>>>>,
+    output_buffer_in_use: AtomicBool,
+}
 
 impl Connection {
-    pub fn get_output_buffer(&self) -> Option<&mut Vec<u8>> {
-        self.output_buffer.as_mut()
+    pub fn get_output_buffer(&self) -> Option<std::sync::MutexGuard<Option<Vec<u8>>>> {
+        // Acquire lock to safely access the output buffer
+        let mut buffer_lock = self.output_buffer.lock().unwrap();
+
+        // Prevent re-entrant or concurrent use of the output buffer (race condition fix)
+        if self.output_buffer_in_use.swap(true, Ordering::Acquire) {
+            // Already in use, return None to avoid use-after-free
+            None
+        } else {
+            Some(buffer_lock)
+        }
     }
+
+    pub fn release_output_buffer(&self) {
+        self.output_buffer_in_use.store(false, Ordering::Release);
+    }
 }
 
