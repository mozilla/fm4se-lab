-// Previously removed cross-process serialization of AndroidHardwareBuffer.
+// Re-enable cross-process serialization of AndroidHardwareBuffer by passing native handles via file descriptors.
+
+#include "AndroidHardwareBufferIPC.h"
+#include "mozilla/ipc/UnixSocket.h"
+#include "mozilla/ipc/PAndroidHardwareBufferParent.h"
+#include "mozilla/ipc/PAndroidHardwareBufferChild.h"
+#include "gfx/layers/AndroidHardwareBuffer.h"
+
+namespace mozilla {
+namespace ipc {
+
+bool
+SerializeAndroidHardwareBuffer(IPC::Message* aMsg, const AndroidHardwareBuffer& aBuffer)
+{
+  const AndroidHardwareBufferHandle& handle = aBuffer.GetHandle();
+  // Validate handle
+  if (!handle.IsValid()) {
+    return false;
+  }
+
+  // Send number of fds
+  aMsg->WriteInt32(handle.fds.size());
+  for (int fd : handle.fds) {
+    aMsg->WriteFileDescriptor(fd);
+  }
+  // Serialize other handle data excluding fds
+  aMsg->Write(handle.metadata);
+  return true;
+}
+
+bool
+DeserializeAndroidHardwareBuffer(IPC::Message* aMsg, AndroidHardwareBuffer* aBuffer)
+{
+  int32_t numFds = 0;
+  if (!aMsg->ReadInt32(&numFds) || numFds < 0) {
+    return false;
+  }
+  AndroidHardwareBufferHandle handle;
+  for (int i = 0; i < numFds; i++) {
+    int fd;
+    if (!aMsg->ReadFileDescriptor(&fd)) {
+      return false;
+    }
+    handle.fds.push_back(fd);
+  }
+  if (!aMsg->Read(&handle.metadata)) {
+    return false;
+  }
+  aBuffer->InitWithHandle(handle);
+  return true;
+}
+
+} // namespace ipc
+} // namespace mozilla
