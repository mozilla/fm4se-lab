+                                                      IProtocol* aActor,
+                                                      mozilla::gfx::AndroidHardwareBuffer* aResult)
+{
+  return mozilla::ipc::DeserializeAndroidHardwareBuffer(const_cast<IPC::Message*>(aMsg), aResult);
+}
