+AndroidHardwareBuffer::AndroidHardwareBuffer(const AndroidHardwareBufferHandle& aHandle)
+  : mHandle(aHandle)
+  , mMonitor("AndroidHardwareBuffer::Monitor")
+  , mRegistered(false)
+{
+  // Only register if the manager exists in this process
+  if (AndroidHardwareBufferManager::Get()) {
+    AndroidHardwareBufferManager::Get()->Register(this);
+    mRegistered = true;
+  }
+}
+
+AndroidHardwareBuffer::~AndroidHardwareBuffer()
+{
+  if (mRegistered && AndroidHardwareBufferManager::Get()) {
+    AndroidHardwareBufferManager::Get()->Unregister(this);
+  }
+}
+
+// Fence synchronization only for same-process buffers
+bool
+AndroidHardwareBuffer::WaitForFenceIfNeeded()
+{
+  if (!mHandle.fenceFd) {
+    return true;
+  }
+  if (!mRegistered) {
+    // Can't synchronize fences across processes
+    return true;
+  }
+  // Perform fence wait as usual
+  return WaitOnFenceFd(mHandle.fenceFd);
+}
+
+// Add method to support constructing without registration
+AndroidHardwareBuffer::AndroidHardwareBuffer()
+  : mMonitor("AndroidHardwareBuffer::Monitor")
+  , mRegistered(false)
+{
+}
+
+void
+AndroidHardwareBuffer::InitWithHandle(const AndroidHardwareBufferHandle& aHandle)
+{
+  mHandle = aHandle;
+}
