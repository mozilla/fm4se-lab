-// Constructor requires registration with AndroidHardwareBufferManager.
-AndroidHardwareBuffer::AndroidHardwareBuffer(const AndroidHardwareBufferHandle& aHandle)
-  : mHandle(aHandle)
-{
-  MOZ_ASSERT(AndroidHardwareBufferManager::Get());
-  AndroidHardwareBufferManager::Get()->Register(this);
