-// This allows closing the comment with '-->' inside user content.
-// Instead, escape or encode all occurrences of '--' and '>' to prevent breaking out.
+// Fix: escape all occurrences of '--' and '>' inside the comment wrapper.
+// Since this is a simplified patch, we add a helper function to escape comment content.
+
+static void EscapeHTMLCommentContent(nsCString& aContent)
+{
+  // Replace all occurrences of '--' with '- -'
+  // and '>' with '&gt;' inside the content to prevent closing comment injection.
+  aContent.ReplaceSubstring("--", "- -");
+  aContent.ReplaceSubstring(">", "&gt;");
+}
+
+// Then, before wrapping content in <!-- ... -->, call EscapeHTMLCommentContent.
+
+// Example modification in the function that does wrapping:
+
+void nsUnknownDecoder::WrapInHTMLComment(nsCString& aData)
+{
+  EscapeHTMLCommentContent(aData);
+  aData.Insert("<!--", 0);
+  aData.Append("-->");
+}
